class GaussMarkDetector:
    """Detector for GaussMark watermark based on gradient correlation"""
    
    def __init__(self, 
                 model,
                 tokenizer,
                 target_weight,
                 original_weight,
                 sigma: float = 1e-4,
                 alpha: float = 0.05):
        self.model = model
        self.tokenizer = tokenizer
        self.target_weight = target_weight
        self.original_weight = original_weight
        self.sigma = sigma
        self.alpha = alpha
        self.device = next(model.parameters()).device
    
    def compute_test_statistic(self, 
                               text: str, 
                               key: torch.Tensor,
                               prompt: Optional[str] = None) -> float:
        """
        Compute watermark detection test statistic.
        
        The key insight: if text y was generated with weights θ + σ*ξ,
        then the gradient ∇_θ log p_θ(y|x) at original weights θ should
        be positively correlated with ξ.
        
        Test statistic: ψ = ⟨ξ, ∇⟩ / ∥∇∥
        
        Under H0 (no watermark/wrong key): ψ ~ N(0, 1) since ξ ~ N(0, I)
        Under H1 (correct key): ψ has positive mean
        """
        if prompt:
            full_text = prompt + text
            prompt_tokens = self.tokenizer(prompt, return_tensors="pt")
            prompt_length = prompt_tokens.input_ids.shape[1]
        else:
            full_text = text
            prompt_length = 0
        
        inputs = self.tokenizer(full_text, return_tensors="pt", truncation=True, max_length=1024)
        input_ids = inputs.input_ids.to(self.device)
        
        # Create labels with prompt tokens masked
        labels = input_ids.clone()
        if prompt_length > 0:
            labels[:, :prompt_length] = -100
        
        # Enable gradient computation
        self.target_weight.requires_grad_(True)
        
        try:
            outputs = self.model(input_ids, labels=labels)
            loss = outputs.loss
            
            # Compute gradient of log-likelihood (negate loss)
            (-loss).backward()
            
            grad = self.target_weight.grad
            
            if grad is None:
                return 0.0
            
            # Flatten for inner product
            key_flat = key.flatten().float().to(self.device)
            grad_flat = grad.flatten().float()
            
            grad_norm = torch.norm(grad_flat)
            
            if grad_norm < 1e-10:
                return 0.0
            
            # Test statistic: ψ = ⟨ξ, ∇⟩ / ∥∇∥
            # Under H0: ξ is independent of ∇, so ψ ~ N(0, 1)
            # Under H1: ψ has positive mean proportional to sigma
            inner_product = torch.dot(key_flat, grad_flat)
            test_stat = inner_product / grad_norm
            
            return test_stat.item()
            
        finally:
            self.target_weight.requires_grad_(False)
            if self.target_weight.grad is not None:
                self.target_weight.grad.zero_()
    
    def detect(self, 
               text: str, 
               key: torch.Tensor,
               prompt: Optional[str] = None) -> Dict:
        """Detect watermark in text"""
        
        if len(text.strip()) < 10:
            return {
                "is_watermarked": False,
                "confidence": 0.0,
                "z_score": 0.0,
                "p_value": 1.0,
                "threshold": float(stats.norm.ppf(1 - self.alpha)),
                "num_tokens": 0
            }
        
        test_stat = self.compute_test_statistic(text, key, prompt)
        
        # Under H0: ψ ~ N(0, 1) approximately
        p_value = 1 - stats.norm.cdf(test_stat)
        threshold = stats.norm.ppf(1 - self.alpha)
        is_watermarked = test_stat > threshold
        
        # Count tokens
        tokens = self.tokenizer.encode(text)
        num_tokens = len(tokens)
        
        return {
            "is_watermarked": bool(is_watermarked),
            "confidence": float(1 - p_value),
            "z_score": float(test_stat),
            "p_value": float(p_value),
            "threshold": float(threshold),
            "num_tokens": int(num_tokens)
        }


class Llama2GaussMarkLFQA:
    """Llama 2 7B model for LFQA dataset processing with GaussMark watermarking"""
    
    def __init__(self, 
                 model_name: str = "meta-llama/Llama-2-7b-hf",
                 load_in_8bit: bool = False,
                 load_in_4bit: bool = False,
                 sigma: float = 1e-4,
                 watermark_layer: int = 16,
                 watermark_component: str = "up_proj",
                 alpha: float = 0.05):
        
        self.model_name = model_name
        self.device = "cuda" if torch.cuda.is_available() else "cpu"
        self.load_in_8bit = load_in_8bit
        self.load_in_4bit = load_in_4bit if not load_in_8bit else False
        
        # Watermark parameters
        self.sigma = sigma
        self.watermark_layer = watermark_layer
        self.watermark_component = watermark_component
        self.alpha = alpha
        
        print("="*80)
        print("LLAMA 2 7B - LFQA DATASET WITH GAUSSMARK WATERMARKING (FIXED)")
        print("="*80)
        print(f"Model: {model_name}")
        print(f"Watermark parameters: sigma={sigma}, layer={watermark_layer}, component={watermark_component}")
        print(f"Detection threshold alpha: {alpha}")
        
        self._load_model()
        self._setup_watermark()
    
    def _load_model(self):
        """Load model with configuration"""
        print(f"\nLoading {self.model_name}...")
        
        self.tokenizer = AutoTokenizer.from_pretrained(self.model_name)
        self.tokenizer.pad_token = self.tokenizer.eos_token
        self.tokenizer.padding_side = "left"
        
        if self.load_in_4bit:
            print("Using 4-bit quantization (WARNING: may affect watermark accuracy)")
            quantization_config = BitsAndBytesConfig(
                load_in_4bit=True,
                bnb_4bit_compute_dtype=torch.float16,
                bnb_4bit_quant_type="nf4",
                bnb_4bit_use_double_quant=True
            )
            self.model = AutoModelForCausalLM.from_pretrained(
                self.model_name,
                quantization_config=quantization_config,
                device_map="auto",
                torch_dtype=torch.float16,
                low_cpu_mem_usage=True
            )
        elif self.load_in_8bit:
            print("Using 8-bit quantization")
            quantization_config = BitsAndBytesConfig(load_in_8bit=True)
            self.model = AutoModelForCausalLM.from_pretrained(
                self.model_name,
                quantization_config=quantization_config,
                device_map="auto",
                torch_dtype=torch.float16,
                low_cpu_mem_usage=True
            )
        else:
            print("Using full precision (fp16)")
            self.model = AutoModelForCausalLM.from_pretrained(
                self.model_name,
                torch_dtype=torch.float16,
                device_map="auto",
                low_cpu_mem_usage=True
            )
        
        print(f"Model loaded successfully!")
        if torch.cuda.is_available():
            print(f"VRAM allocated: {torch.cuda.memory_allocated() / 1e9:.2f} GB")
    
    def _setup_watermark(self):
        """Setup watermark target weight and detector"""
        self.target_weight = self._get_target_weight()
        self.weight_shape = self.target_weight.shape
        self.weight_dim = self.target_weight.numel()
        
        with torch.no_grad():
            self.original_weight = self.target_weight.data.clone().float()
        
        print(f"Watermark target: layer {self.watermark_layer}, {self.watermark_component}")
        print(f"Target weight shape: {self.weight_shape}")
        print(f"Target weight dimension: {self.weight_dim:,} elements")
        print(f"Expected perturbation norm: ||δ|| ≈ σ√d = {self.sigma * np.sqrt(self.weight_dim):.4f}")
        
        self._update_detector()
    
    def _update_detector(self):
        """Update detector with current sigma"""
        self.detector = GaussMarkDetector(
            model=self.model,
            tokenizer=self.tokenizer,
            target_weight=self.target_weight,
            original_weight=self.original_weight,
            sigma=self.sigma,
            alpha=self.alpha
        )
    
    def set_sigma(self, sigma: float):
        """Update sigma value"""
        self.sigma = sigma
        self._update_detector()
        print(f"Sigma updated to {sigma}, expected ||δ|| ≈ {sigma * np.sqrt(self.weight_dim):.4f}")
    
    def _get_target_weight(self) -> torch.nn.Parameter:
        """Get the target weight for watermarking"""
        layers = self.model.model.layers
        layer = layers[self.watermark_layer]
        
        component_map = {
            "up_proj": layer.mlp.up_proj,
            "down_proj": layer.mlp.down_proj,
            "gate_proj": layer.mlp.gate_proj,
        }
        
        module = component_map[self.watermark_component]
        return module.weight
    
    def generate_key(self, seed: Optional[int] = None) -> torch.Tensor:
        """
        Generate a random watermark key.
        
        FIXED: ξ ~ N(0, I) - standard normal, NOT normalized!
        The sigma scaling happens in apply_watermark.
        """
        if seed is not None:
            torch.manual_seed(seed)
        
        # DO NOT normalize! Each element should be ~ N(0, 1)
        key = torch.randn(self.weight_shape, dtype=torch.float32)
        return key
    
    def apply_watermark(self, key: torch.Tensor):
        """
        Apply watermark to model weights.
        
        θ(ξ) = θ + σξ where ξ ~ N(0, I)
        """
        with torch.no_grad():
            # Scale key by sigma: perturbation = σ * ξ
            delta = self.sigma * key.to(self.target_weight.device)
            if self.target_weight.dtype != torch.float32:
                delta = delta.to(self.target_weight.dtype)
            self.target_weight.data = self.original_weight.to(
                self.target_weight.device
            ).to(self.target_weight.dtype) + delta
    
    def remove_watermark(self):
        """Remove watermark and restore original weights"""
        with torch.no_grad():
            self.target_weight.data = self.original_weight.to(
                self.target_weight.device
            ).to(self.target_weight.dtype)
    
    def generate_watermarked(self,
                             prompt: str,
                             key: torch.Tensor,
                             max_new_tokens: int = 300,
                             temperature: float = 0.7,
                             top_p: float = 0.9,
                             top_k: int = 50,
                             do_sample: bool = True) -> str:
        """Generate watermarked text"""
        
        self.apply_watermark(key)
        
        try:
            inputs = self.tokenizer(
                prompt, 
                return_tensors="pt", 
                truncation=True, 
                max_length=512
            ).to(self.device)
            
            input_length = inputs.input_ids.shape[1]
            
            with torch.no_grad():
                outputs = self.model.generate(
                    **inputs,
                    max_new_tokens=max_new_tokens,
                    temperature=temperature,
                    top_p=top_p,
                    top_k=top_k,
                    do_sample=do_sample,
                    pad_token_id=self.tokenizer.pad_token_id,
                )
            
            generated_text = self.tokenizer.decode(
                outputs[0][input_length:], 
                skip_special_tokens=True
            )
            
            return generated_text
            
        finally:
            self.remove_watermark()
    
    def generate_unwatermarked(self,
                               prompt: str,
                               max_new_tokens: int = 300,
                               temperature: float = 0.7,
                               top_p: float = 0.9,
                               top_k: int = 50,
                               do_sample: bool = True) -> str:
        """Generate text without watermark"""
        
        inputs = self.tokenizer(
            prompt, 
            return_tensors="pt", 
            truncation=True, 
            max_length=512
        ).to(self.device)
        
        input_length = inputs.input_ids.shape[1]
        
        with torch.no_grad():
            outputs = self.model.generate(
                **inputs,
                max_new_tokens=max_new_tokens,
                temperature=temperature,
                top_p=top_p,
                top_k=top_k,
                do_sample=do_sample,
                pad_token_id=self.tokenizer.pad_token_id,
            )
        
        generated_text = self.tokenizer.decode(
            outputs[0][input_length:], 
            skip_special_tokens=True
        )
        
        return generated_text
    
