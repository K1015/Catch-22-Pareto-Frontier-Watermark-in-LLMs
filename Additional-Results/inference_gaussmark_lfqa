    def sigma_sweep(self, 
                    sigma_values: List[float],
                    num_samples: int = 10) -> Dict:
        """Sweep through sigma values to find optimal setting"""
        print("\n" + "="*60)
        print("SIGMA SWEEP")
        print("="*60)
        
        prompts = [
            "What is machine learning?",
            "Explain quantum computing.",
            "How does photosynthesis work?",
            "What causes climate change?",
            "Describe the solar system.",
            "What is artificial intelligence?",
            "How do vaccines work?",
            "Explain the theory of relativity.",
            "What are black holes?",
            "How does the internet work?",
        ][:num_samples]
        
        results = {}
        
        for sigma in sigma_values:
            print(f"\n--- Testing sigma = {sigma} ---")
            self.set_sigma(sigma)
            
            correct_z = []
            wrong_z = []
            
            for i, prompt in enumerate(tqdm(prompts, desc=f"sigma={sigma}")):
                key = self.generate_key(seed=i+1000)
                wrong_key = self.generate_key(seed=i+50000)
                
                wm_text = self.generate_watermarked(prompt, key, max_new_tokens=150)
                
                det_correct = self.detector.detect(wm_text, key, prompt)
                det_wrong = self.detector.detect(wm_text, wrong_key, prompt)
                
                correct_z.append(det_correct["z_score"])
                wrong_z.append(det_wrong["z_score"])
            
            tpr = np.mean([z > 1.645 for z in correct_z])
            fpr = np.mean([z > 1.645 for z in wrong_z])
            mean_z = np.mean(correct_z)
            
            results[sigma] = {
                "tpr": tpr,
                "fpr": fpr,
                "mean_z_correct": mean_z,
                "mean_z_wrong": np.mean(wrong_z),
                "std_z_correct": np.std(correct_z),
            }
            
            print(f"  TPR: {tpr:.1%}, FPR: {fpr:.1%}, Mean z-score: {mean_z:.3f}")
        
        # Find best sigma
        best_sigma = max(results.keys(), key=lambda s: results[s]["tpr"] - results[s]["fpr"])
        
        print("\n" + "="*60)
        print("SIGMA SWEEP RESULTS")
        print("="*60)
        print(f"{'Sigma':<12} {'TPR':<10} {'FPR':<10} {'Mean Z':<10} {'Quality':<10}")
        print("-"*52)
        for sigma in sigma_values:
            r = results[sigma]
            quality = "★" * min(5, int((1 - r["fpr"]) * 5))
            print(f"{sigma:<12.1e} {r['tpr']:<10.1%} {r['fpr']:<10.1%} {r['mean_z_correct']:<10.3f} {quality}")
        print("-"*52)
        print(f"Best sigma: {best_sigma} (TPR={results[best_sigma]['tpr']:.1%}, FPR={results[best_sigma]['fpr']:.1%})")
        print("="*60)
        
        return {"results": results, "best_sigma": best_sigma}
    
    def process_lfqa_dataset(self,
                             input_file: str,
                             output_dir: str,
                             num_samples: int = 500,
                             max_new_tokens: int = 300,
                             batch_save: int = 10,
                             generate_baseline: bool = False):
        """Process LFQA dataset with GaussMark watermarking"""
        
        os.makedirs(output_dir, exist_ok=True)
        
        output_file = os.path.join(
            output_dir,
            f"gaussmark_fixed_{self.model_name.replace('/', '-')}_sigma_{self.sigma}_"
            f"layer_{self.watermark_layer}_len_{max_new_tokens}_num_{num_samples}.jsonl"
        )
        
        print(f"\nLoading dataset from {input_file}")
        if not os.path.exists(input_file):
            print(f"Error: Input file {input_file} not found!")
            self._create_sample_dataset(input_file)
        
        with open(input_file, 'r') as f:
            lines = f.read().strip().split('\n')
            data = [json.loads(line) for line in lines if line]
        
        # Check for existing outputs
        start_idx = 0
        if os.path.exists(output_file):
            try:
                with open(output_file, 'r') as f:
                    content = f.read().strip()
                    if content:
                        existing = [json.loads(line) for line in content.split('\n')]
                        start_idx = len(existing)
                print(f"Resuming from index {start_idx}...")
            except:
                pass
        
        outputs = []
        
        print(f"\nProcessing {min(num_samples, len(data))} samples...")
        print(f"Watermark: sigma={self.sigma}, expected ||δ|| ≈ {self.sigma * np.sqrt(self.weight_dim):.4f}")
        
        for idx in tqdm(range(start_idx, min(num_samples, len(data))), desc="Generating"):
            sample = data[idx]
            prompt = sample.get("prefix", sample.get("question", sample.get("prompt", "")))
            gold = sample.get("gold_completion", sample.get("targets", [""])[0] if isinstance(sample.get("targets"), list) else sample.get("targets", ""))
            
            try:
                key_seed = idx + 1000
                key = self.generate_key(seed=key_seed)
                
                wm_text = self.generate_watermarked(prompt, key, max_new_tokens)
                det = self.detector.detect(wm_text, key, prompt)
                
                wrong_key = self.generate_key(seed=key_seed + 50000)
                det_wrong = self.detector.detect(wm_text, wrong_key, prompt)
                
                output_entry = {
                    "idx": int(idx),
                    "prefix": str(prompt),
                    "gold_completion": str(gold) if gold else "",
                    "gen_completion": [str(wm_text)],
                    "watermark_params": {
                        "sigma": float(self.sigma),
                        "layer": int(self.watermark_layer),
                        "component": str(self.watermark_component),
                        "key_seed": int(key_seed),
                        "method": "gaussmark_fixed"
                    },
                    "detection_stats": {
                        "z_score": float(det["z_score"]),
                        "p_value": float(det["p_value"]),
                        "is_watermarked": bool(det["is_watermarked"]),
                        "confidence": float(det["confidence"]),
                        "threshold": float(det["threshold"]),
                        "num_tokens": int(det["num_tokens"])
                    },
                    "wrong_key_detection": {
                        "z_score": float(det_wrong["z_score"]),
                        "p_value": float(det_wrong["p_value"]),
                        "is_watermarked": bool(det_wrong["is_watermarked"])
                    }
                }
                
                if generate_baseline:
                    baseline_text = self.generate_unwatermarked(prompt, max_new_tokens)
                    det_baseline = self.detector.detect(baseline_text, key, prompt)
                    output_entry["baseline_text"] = str(baseline_text)
                    output_entry["baseline_detection"] = {
                        "z_score": float(det_baseline["z_score"]),
                        "p_value": float(det_baseline["p_value"]),
                        "is_watermarked": bool(det_baseline["is_watermarked"])
                    }
                
                outputs.append(json.dumps(output_entry))
                
                if len(outputs) >= batch_save:
                    with open(output_file, 'a') as f:
                        f.write('\n'.join(outputs) + '\n')
                    outputs = []
                    if torch.cuda.is_available():
                        torch.cuda.empty_cache()
                        
            except Exception as e:
                print(f"\nError at sample {idx}: {e}")
                import traceback
                traceback.print_exc()
                continue
        
        if outputs:
            with open(output_file, 'a') as f:
                f.write('\n'.join(outputs) + '\n')
        
        print(f"\nOutput saved to: {output_file}")
        return self._compute_summary_stats(output_file)
    
    def _create_sample_dataset(self, filepath):
        """Create sample dataset"""
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        samples = [
            {"prefix": "What is machine learning and how does it work?"},
            {"prefix": "Explain the causes and effects of climate change."},
            {"prefix": "How does photosynthesis work in plants?"},
            {"prefix": "What is quantum computing and its applications?"},
            {"prefix": "Describe the structure of our solar system."},
        ]
        with open(filepath, 'w') as f:
            for s in samples:
                f.write(json.dumps(s) + '\n')
        print(f"Created sample dataset at {filepath}")
    
    def _compute_summary_stats(self, output_file: str) -> Dict:
        """Compute summary statistics"""
        try:
            with open(output_file, 'r') as f:
                results = [json.loads(line) for line in f.read().strip().split('\n') if line]
            
            if not results:
                return {}
            
            z_scores = [r["detection_stats"]["z_score"] for r in results]
            detected = [r["detection_stats"]["is_watermarked"] for r in results]
            wrong_z = [r["wrong_key_detection"]["z_score"] for r in results]
            wrong_detected = [r["wrong_key_detection"]["is_watermarked"] for r in results]
            
            from sklearn.metrics import roc_auc_score
            labels = [1] * len(z_scores) + [0] * len(wrong_z)
            scores = z_scores + wrong_z
            auroc = roc_auc_score(labels, scores) if len(set(labels)) > 1 else 0.5
            
            stats = {
                "total_samples": len(results),
                "watermark_params": results[0]["watermark_params"],
                "detection_results": {
                    "true_positive_rate": float(np.mean(detected)),
                    "false_positive_rate_wrong_key": float(np.mean(wrong_detected)),
                    "auroc": float(auroc)
                },
                "z_score_stats": {
                    "mean": float(np.mean(z_scores)),
                    "std": float(np.std(z_scores)),
                    "median": float(np.median(z_scores)),
                    "min": float(min(z_scores)),
                    "max": float(max(z_scores))
                }
            }
            
            print("\n" + "="*60)
            print("GAUSSMARK DETECTION SUMMARY (FIXED)")
            print("="*60)
            print(f"Total samples: {stats['total_samples']}")
            print(f"Sigma: {stats['watermark_params']['sigma']}")
            print(f"\nDetection Results:")
            print(f"  True Positive Rate:  {stats['detection_results']['true_positive_rate']:.1%}")
            print(f"  False Positive Rate: {stats['detection_results']['false_positive_rate_wrong_key']:.1%}")
            print(f"  AUROC:               {stats['detection_results']['auroc']:.4f}")
            print(f"\nZ-Score (correct key):")
            print(f"  Mean: {stats['z_score_stats']['mean']:.3f}, Std: {stats['z_score_stats']['std']:.3f}")
            print(f"  Min: {stats['z_score_stats']['min']:.3f}, Max: {stats['z_score_stats']['max']:.3f}")
            print("="*60)
            
            return stats
        except Exception as e:
            print(f"Error computing stats: {e}")
            return {}


def main():
    parser = argparse.ArgumentParser(description="GaussMark Watermarking (Fixed)")
    parser.add_argument("--mode", type=str, default="test",
                        choices=["test", "sweep", "evaluate"],
                        help="Mode: test (quick test), sweep (sigma sweep), evaluate (full dataset)")
    parser.add_argument("--model", type=str, default="meta-llama/Llama-2-7b-hf")
    parser.add_argument("--input_file", type=str, default="./data/LFQA/inputs.jsonl")
    parser.add_argument("--output_dir", type=str, default="./data/LFQA/")
    parser.add_argument("--num_samples", type=int, default=50)
    parser.add_argument("--max_new_tokens", type=int, default=300)
    parser.add_argument("--sigma", type=float, default=0.01)
    parser.add_argument("--layer", type=int, default=16)
    parser.add_argument("--component", type=str, default="up_proj")
    parser.add_argument("--alpha", type=float, default=0.05)
    parser.add_argument("--load_in_4bit", action="store_true")
    
    args = parser.parse_args()
    
    processor = Llama2GaussMarkLFQA(
        model_name=args.model,
        load_in_4bit=args.load_in_4bit,
        sigma=args.sigma,
        watermark_layer=args.layer,
        watermark_component=args.component,
        alpha=args.alpha
    )
    
    if args.mode == "test":
        # Quick test
        processor.quick_test(num_samples=5)
        
    elif args.mode == "sweep":
        # Sigma sweep
        sigma_values = [1e-5, 5e-5, 1e-4, 5e-4, 1e-3, 5e-3, 1e-2]
        results = processor.sigma_sweep(sigma_values, num_samples=min(10, args.num_samples))
        
        # Save results
        os.makedirs(args.output_dir, exist_ok=True)
        with open(os.path.join(args.output_dir, "sigma_sweep_results.json"), 'w') as f:
            json.dump(results, f, indent=2, default=float)
        
    elif args.mode == "evaluate":
        # Full evaluation
        stats = processor.process_lfqa_dataset(
            input_file=args.input_file,
            output_dir=args.output_dir,
            num_samples=args.num_samples,
            max_new_tokens=args.max_new_tokens
        )
        
        if stats:
            with open(os.path.join(args.output_dir, f"gaussmark_stats_fixed_sigma_{args.sigma}.json"), 'w') as f:
                json.dump(stats, f, indent=2)
    
    print("\nDone!")


if __name__ == "__main__":
    main()
